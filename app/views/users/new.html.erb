<div class="min-h-screen flex items-center justify-center bg-gray-100">
  <div class="w-full max-w-md bg-white rounded-lg shadow-md p-8">
    <h1 class="text-3xl font-bold mb-6 text-center text-gray-800">Sign Up</h1>
    <%= form_with model: @user, url: signup_path, local: true do |form| %>
      <% if @user.errors.any? %>
        <div class="mb-4 p-4 bg-red-100 border border-red-400 text-red-700 rounded">
          <h2 class="font-semibold mb-2"><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</h2>
          <ul class="list-disc list-inside">
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      <div class="mb-4">
        <%= form.label :name, class: "block text-gray-700 font-semibold mb-2" %>
        <%= form.text_field :name, class: "w-full px-3 py-2 border rounded focus:outline-none focus:ring-2 focus:ring-blue-400" %>
      </div>
      <div class="mb-4">
        <%= form.label :email, class: "block text-gray-700 font-semibold mb-2" %>
        <%= form.email_field :email, class: "w-full px-3 py-2 border rounded focus:outline-none focus:ring-2 focus:ring-blue-400" %>
      </div>
      <div class="mb-4">
        <%= form.label :password, class: "block text-gray-700 font-semibold mb-2" %>
        <%= form.password_field :password, class: "w-full px-3 py-2 border rounded focus:outline-none focus:ring-2 focus:ring-blue-400" %>
      </div>
      <div class="mb-4">
        <%= form.label :password_confirmation, class: "block text-gray-700 font-semibold mb-2" %>
        <%= form.password_field :password_confirmation, class: "w-full px-3 py-2 border rounded focus:outline-none focus:ring-2 focus:ring-blue-400" %>
      </div>
      <div class="mb-6">
        <%= form.submit "Sign Up", class: "w-full bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded transition duration-200" %>
      </div>
    <% end %>
    <p class="text-center text-gray-600">Already have an account? <%= link_to 'Log in', login_path, class: "text-blue-500 hover:underline" %></p>
  </div>
</div>
